{
  "name": "vscode-better-color-highlight",
  "displayName": "Better Color Highlight",
  "version": "0.0.0",
  "description": "Highlight and preview colors in multiple formats across code, comments, and strings.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "color",
    "color highlight",
    "color picker",
    "color preview",
    "colour",
    "css",
    "design tokens",
    "github.dev",
    "hex",
    "highlight",
    "hsl",
    "hsla",
    "hwb",
    "lab",
    "lch",
    "oklab",
    "oklch",
    "preview",
    "rgb",
    "rgba",
    "tailwind",
    "vscode web",
    "vscode.dev",
    "web"
  ],
  "homepage": "https://github.com/ntnyq/vscode-better-color-highlight",
  "bugs": {
    "url": "https://github.com/ntnyq/vscode-better-color-highlight/issues/new"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/vscode-better-color-highlight",
  "publisher": "ntnyq",
  "files": [
    "LICENSE",
    "dist/*",
    "res/*"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "browser": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate:meta": "vscode-ext-gen --output src/meta.ts --scope=color-highlight",
    "lint": "oxlint",
    "pack": "vsce package --no-dependencies",
    "prepare": "husky",
    "release": "run-s release:check release:version release:publish",
    "release:build": "run-s generate:meta build",
    "release:check": "run-s format:check lint typecheck test",
    "release:publish": "vsce publish --no-dependencies",
    "release:version": "bumpp --all --execute='pnpm release:build'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "reactive-vscode": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.125.0",
    "@typescript/native-preview": "^7.0.0-dev.20260622.1",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9",
    "vscode-ext-gen": "^1.6.0"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "contributes": {
    "configuration": {
      "title": "Better Color Highlight",
      "properties": {
        "color-highlight.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable color highlighting."
        },
        "color-highlight.languages": {
          "type": "array",
          "default": [
            "*"
          ],
          "items": {
            "type": "string"
          },
          "description": "Language IDs where colors are highlighted. Use '*' for all languages, prefix with '!' to exclude."
        },
        "color-highlight.matchWords": {
          "type": "boolean",
          "default": false,
          "description": "Highlight named CSS colors (e.g., 'red', 'blue') in non-style languages."
        },
        "color-highlight.namedColorMatchMode": {
          "type": "string",
          "default": "context",
          "enum": [
            "context",
            "always",
            "never"
          ],
          "description": "Controls named CSS color matching. 'context' matches style-language declaration values, 'always' matches any named color word, and 'never' disables named color matching."
        },
        "color-highlight.resolveScssVariablesAcrossFiles": {
          "type": "boolean",
          "default": false,
          "description": "Resolve SCSS variables through local @use, @forward, and @import dependencies. Disabled by default to avoid extra file-system work."
        },
        "color-highlight.scssLoadPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional Sass load paths for resolving non-relative SCSS @use, @forward, and @import modules."
        },
        "color-highlight.useARGB": {
          "type": "boolean",
          "default": false,
          "description": "Interpret 8-digit hex colors as ARGB instead of RGBA."
        },
        "color-highlight.matchRgbWithNoFunction": {
          "type": "boolean",
          "default": false,
          "description": "Highlight RGB values not wrapped in rgb() function."
        },
        "color-highlight.rgbWithNoFunctionLanguages": {
          "type": "array",
          "default": [
            "*"
          ],
          "items": {
            "type": "string"
          },
          "description": "Language IDs for rgb-without-function matching. Use '*' / '!' syntax."
        },
        "color-highlight.matchHslWithNoFunction": {
          "type": "boolean",
          "default": false,
          "description": "Highlight HSL values not wrapped in hsl() function."
        },
        "color-highlight.hslWithNoFunctionLanguages": {
          "type": "array",
          "default": [
            "*"
          ],
          "items": {
            "type": "string"
          },
          "description": "Language IDs for hsl-without-function matching. Use '*' / '!' syntax."
        },
        "color-highlight.markerType": {
          "type": "string",
          "default": "background",
          "enum": [
            "background",
            "outline",
            "foreground",
            "underline",
            "dot-before",
            "dot-after"
          ],
          "description": "Style of the color highlight marker."
        },
        "color-highlight.markRuler": {
          "type": "boolean",
          "default": true,
          "description": "Show color indicators on the scrollbar ruler."
        },
        "color-highlight.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for color detection and decoration."
        }
      }
    },
    "commands": [
      {
        "category": "Color Highlight",
        "command": "color-highlight.enable",
        "title": "Enable Better Color Highlight"
      },
      {
        "category": "Color Highlight",
        "command": "color-highlight.disable",
        "title": "Disable Better Color Highlight"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "https://ntnyq.com/static/icons/icon-192x192.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "packageManager": "pnpm@11.8.0",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  }
}
